# Build stage
FROM oven/bun:alpine AS build
WORKDIR /app
COPY package.json ./
ARG VITE_API_URL=/api
ENV VITE_API_URL=$VITE_API_URL
RUN bun install
COPY . .
RUN bun run build

# Run stage
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
